// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  userLevelId Int       @map("user_level_id")
  employeeId  Int       @map("employee_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  userLevel UserLevel @relation(fields: [userLevelId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])

  @@map("user")
}

model UserLevel {
  id    Int    @id @default(autoincrement())
  level String

  user User[]

  @@map("user_level")
}

model Employee {
  id         Int       @id @default(autoincrement())
  name       String
  nip        String    @unique
  sectionId  Int       @map("section_id")
  positionId Int       @map("position_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  eser       User[]

  position Position @relation(fields: [positionId], references: [id])
  section  Section  @relation(fields: [sectionId], references: [id])

  @@map("employee")
}

model Section {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  employee  Employee[]

  @@map("section")
}

model Position {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  employee  Employee[]

  @@map("position")
}

model IncomingLetter {
  id        Int       @id @default(autoincrement())
  refNo     String    @map("ref_no")
  sender    String
  about     String
  statusId  Int       @map("status_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  dispositionForm DispositionForm[]
  status          Status            @relation(fields: [statusId], references: [id])

  @@map("incoming_letter")
}

model DispositionForm {
  id               Int       @id @default(autoincrement())
  from             Int
  to               Int
  instructions     String
  notes            String?
  incomingLetterId Int       @map("incoming_letter_id")
  priorityId       Int       @map("priority_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  incomingLetter IncomingLetter @relation(fields: [incomingLetterId], references: [id])
  priority       Priority       @relation(fields: [priorityId], references: [id])

  @@map("disposition_form")
}

model OutgoingLetter {
  id       Int    @id @default(autoincrement())
  refNo    String @map("ref_no")
  to       String
  about    String
  statusId Int    @map("status_id")

  status Status @relation(fields: [statusId], references: [id])

  @@map("outgoing_letter")
}

model Status {
  id   Int    @id @default(autoincrement())
  name String

  incomingLetter IncomingLetter[]
  outgoingLetter OutgoingLetter[]

  @@map("status")
}

model Priority {
  id      Int    @id @default(autoincrement())
  urgency String

  dispositionForm DispositionForm[]

  @@map("priority")
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  key       String
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_key")
}
