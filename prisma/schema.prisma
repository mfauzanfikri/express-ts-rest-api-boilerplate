// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  userLevelId Int       @map("user_level_id")
  employeeId  Int       @map("employee_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  userLevel UserLevel @relation(fields: [userLevelId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("user")
}

model UserLevel {
  id    Int    @id @default(autoincrement())
  level String

  user User[]

  @@map("user_level")
}

model Employee {
  id        Int       @id @default(autoincrement())
  name      String
  nip       String?   @unique
  nik       String?   @unique
  sectionId Int       @map("section_id")
  // positionId Int       @map("position_id")
  // section   String
  position  String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user       User[]
  // position Position @relation(fields: [positionId], references: [id])
  section    Section   @relation(fields: [sectionId], references: [id])
  Position   Position? @relation(fields: [positionId], references: [id])
  positionId Int?

  @@map("employee")
}

model Section {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  employee Employee[]

  @@map("section")
}

model Position {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  employee Employee[]

  @@map("position")
}

model IncomingLetter {
  id        Int       @id @default(autoincrement())
  refNo     String    @map("ref_no")
  sender    String
  about     String
  date      DateTime
  statusId  Int       @map("status_id")
  path      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  disposition Disposition[]
  status      Status        @relation(fields: [statusId], references: [id])

  @@map("incoming_letter")
}

model Disposition {
  id                  Int       @id @default(autoincrement())
  incomingLetterId    Int       @unique @map("incoming_letter_id")
  dispositionStatusId Int       @map("disposition_status_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")

  incomingLetter    IncomingLetter    @relation(fields: [incomingLetterId], references: [id])
  dispositionStatus DispositionStatus @relation(fields: [dispositionStatusId], references: [id])
  dispositionForm   DispositionForm[]

  @@map("disposition")
}

model DispositionForm {
  id            Int       @id @default(autoincrement())
  from          Int
  to            Int
  notes         String?
  dispositionId Int       @map("dispotision_id")
  instructionId Int       @map("instruction_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  disposition Disposition @relation(fields: [dispositionId], references: [id])
  instruction Instruction @relation(fields: [instructionId], references: [id])

  @@map("disposition_form")
}

model DispositionStatus {
  id   Int    @id @default(autoincrement())
  name String

  disposition Disposition[]

  @@map("disposition_status")
}

model OutgoingLetter {
  id        Int       @id @default(autoincrement())
  refNo     String    @map("ref_no")
  to        String
  about     String
  date      DateTime
  statusId  Int       @map("status_id")
  path      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  status Status @relation(fields: [statusId], references: [id])

  @@map("outgoing_letter")
}

model Status {
  id   Int    @id @default(autoincrement())
  name String

  incomingLetter IncomingLetter[]
  outgoingLetter OutgoingLetter[]

  @@map("status")
}

model Instruction {
  id   Int    @id @default(autoincrement())
  name String

  dispositionForm DispositionForm[]

  @@map("instruction")
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  key       String
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_key")
}
